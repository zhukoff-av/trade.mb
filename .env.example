# Copy to .env and adjust. All values are optional — defaults target the public mb.io site.

# Web app under test (default: https://mb.io)
# BASE_URL=https://mb.io

# Public no-login site under test (default: https://mb.io)
# PUBLIC_BASE_URL=https://mb.io

# API base URL (default: BASE_URL)
# API_URL=https://mb.io

# Bearer token attached to api-project requests when set
# API_TOKEN=

# Local UI authentication through a manually authenticated Chrome CDP session
# AUTH_STATE_PATH=.auth/user.json
# USE_AUTH_STATE=false
# AUTH_CDP_URL=http://127.0.0.1:9222
# AUTH_CHROME_PROFILE_PATH=.auth/chrome-profile
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
