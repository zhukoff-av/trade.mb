# Copy to .env and adjust if the tests should target a different environment.

# Public website under test (default: https://mb.io)
# BASE_URL=https://mb.io

# Authenticated trading portal (default: https://trade.mb.io)
# AUTH_BASE_URL=https://trade.mb.io
# AUTH_STATE_PATH=.auth/user.json

# Authenticated API services
# CORE_API_BASE_URL=https://core-api.mb.io
# MARKET_DATA_API_BASE_URL=https://mbg-market-data-service.mb.io

# Local manual authentication through a loopback-only Chrome CDP session
# AUTH_CDP_URL=http://127.0.0.1:9222
# AUTH_CHROME_PROFILE_PATH=.auth/chrome-profile
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
