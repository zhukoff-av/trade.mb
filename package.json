{
  "name": "trade-mb-qa",
  "version": "1.0.0",
  "description": "Playwright test automation for the public mb.io website",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui",
    "test:headed": "playwright test --project=ui --headed",
    "test:ui-mode": "playwright test --ui",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "plan-coverage": "node scripts/plan-coverage.js",
    "report": "playwright show-report"
  },
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "^22.8.6",
    "dotenv": "^17.4.2",
    "eslint": "^9.14.0",
    "eslint-plugin-playwright": "^2.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  }
}
